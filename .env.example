# PAUSED by default — do not burn shared hibs-bet API keys. Set FVE_PAUSED=0 + dedicated key to resume.
FVE_PAUSED=1

# --- While paused: Matchbook arb research only (no API-Sports). See docs/ARB_FREEZE.md ---
# FVE_ARB_ONLY=1
# DISABLED_FEEDS=api-football,betfair,pinnacle,the-odds-api

# --- Resume path A: dedicated API keys (unpause + own API_SPORTS_KEY) ---
# FVE_PAUSED=0

# --- Resume path B: consume hibs-bet lines (no duplicate book ingest) ---
# 1) On VPS: scripts/vps_install_hibs_fve_lines.sh
# 2) Then set:
# FVE_PAUSED=0
# FVE_UPSTREAM_MODE=hibs
# HIBS_UPSTREAM_BASE_URL=https://hibs-bet.co.uk
# HIBS_UPSTREAM_TOKEN=          # optional — must match hibs FVE_LINES_TOKEN

# --- Resume path C: separate stack (own keys + scrape sidecar + API backups) ---
# See docs/SEPARATE_FEEDS.md
# FVE_PAUSED=0
# FVE_FEED_MODE=separate
# FVE_FEED_CHAIN=matchbook,odds-backup,api-football,scrape-cache
# FVE_SCRAPE_LINES_URL=http://127.0.0.1:8091/lines/{fixture_key}
# FVE_ODDS_BACKUP_SPORT_KEYS=soccer_england_premier_league

# --- Resume path D (recommended zero-API): scrape-heavy — docs/SCRAPE_HEAVY.md ---
# VPS: scripts/vps_unpause_fve_scrape_stack.sh
# Local: scripts/run_scrape_stack.sh
# FVE_PAUSED=0
# FVE_FEED_MODE=scrape
# FVE_SCRAPE_HEAVY=1
# FVE_SCRAPE_LINES_DIR=./data/scrape-lines
# HIBS_UPSTREAM_BASE_URL=https://hibs-bet.co.uk

# Required when unpaused for API-Football watchlist (not needed for FVE_FEED_MODE=scrape)
API_SPORTS_KEY=your_api_football_key

# Optional — exchange lines + arb (map event ids in data/matchbook_map.json)
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=

# Optional — extra soft books (shared quota across repos; feed OFF by default)
ODDS_API_KEY=
ENABLE_ODDS_API_FEED=0

# FVE API port (hibs-bet gunicorn uses :8000 on VPS — use 8010 for FVE)
# FVE_API_PORT=8010
FVE_WATCHLIST_DAYS=3
FVE_WATCHLIST_REFRESH_SEC=3600
# FVE_LEAGUE_IDS=39,140
# FVE_LEAGUE_NAMES=England Premier League,Spain La Liga

# Manual fallback if auto discover returns nothing (required for FVE_ARB_ONLY / arb-shadow)
# WATCHLIST_FIXTURES=Arsenal v Chelsea::12345678

# Arb shadow scan — log opportunities, never submit (docker profile arb-shadow sets these)
# MATCHBOOK_KILL_SWITCH=1
# MATCHBOOK_AUTO_TRADE=0
# ARB_SHADOW_LOG=1

# Shared API budgets (Redis-backed when REDIS_URL set)
FVE_ODDS_API_MAX_CALLS_PER_HOUR=15
FVE_MATCHBOOK_MAX_CALLS_PER_HOUR=1200
FVE_API_FOOTBALL_MAX_CALLS_PER_HOUR=100

REDIS_URL=redis://redis:6379/0
FVE_API_URL=http://localhost:8000

# Inst++ Phase 1 — wire + WS tuning
FVE_WS_DELTA_UPDATES=1          # line_update sends changed_markets only (snapshot stays full)
FVE_WS_CLIENT_DELTA=0          # 0=hub expands deltas to full lines for WS clients; 1=raw delta
FVE_BUS_CODEC=json              # json (orjson) | msgpack for worker↔API pub/sub
FVE_TCP_NODELAY=1               # TCP_NODELAY on Redis sockets
WS_MAX_PENDING_SENDS=8            # drop slow WS clients when send queue backs up
WS_SEND_TIMEOUT_SEC=2.0
FEED_POLL_SEC_MATCHBOOK=0.5     # faster exchange poll (dominant latency win vs serde)

# Institutional pricing (default) — joint score matrix → 1X2 / O2.5 / BTTS
# FVE_PRICING_MODE=institutional   # or independent for legacy Poisson
# FVE_BIVARIATE_POISSON=1
# FVE_BIV_POISSON_SHARED_FRAC=0.22
# FVE_DIXON_COLES=1
# FVE_DIXON_COLES_RHO=-0.13
# FVE_SCORE_MATRIX_MAX_GOALS=10
# FVE_TIME_DECAY=1
# FVE_TIME_DECAY_HALF_LIFE_DAYS=45
# FVE_ATTACK_DEFENCE=1
# FVE_CALIBRATION_PATH=./config/league_calibration.json
# FVE_ML_BLEND_WEIGHT=0.33
# FVE_PORTFOLIO_STAKE_CAP_PCT=20
# FVE_REDIS_BACKEND=dragonfly    # label only — use REDIS_URL=redis://dragonfly:6379/0 with compose profile dragonfly
