# PAUSED by default — do not burn shared hibs-bet API keys. Set FVE_PAUSED=0 + dedicated key to resume.
FVE_PAUSED=1

# --- Resume path A: dedicated API keys (unpause + own API_SPORTS_KEY) ---
# FVE_PAUSED=0

# --- Resume path B: consume hibs-bet lines (no duplicate book ingest) ---
# 1) On VPS: scripts/vps_install_hibs_fve_lines.sh
# 2) Then set:
# FVE_PAUSED=0
# FVE_UPSTREAM_MODE=hibs
# HIBS_UPSTREAM_BASE_URL=https://hibs-bet.co.uk
# HIBS_UPSTREAM_TOKEN=          # optional — must match hibs FVE_LINES_TOKEN

# Required when unpaused for auto watchlist + API-Football feed
API_SPORTS_KEY=your_api_football_key

# Optional — exchange lines + arb (map event ids in data/matchbook_map.json)
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=

# Optional — extra soft books (shared quota across repos; feed OFF by default)
ODDS_API_KEY=
ENABLE_ODDS_API_FEED=0

# Auto watchlist (hands-off worker default in Docker)
FVE_AUTO_WATCHLIST=1
FVE_WATCHLIST_DAYS=3
FVE_WATCHLIST_REFRESH_SEC=3600
# FVE_LEAGUE_IDS=39,140
# FVE_LEAGUE_NAMES=England Premier League,Spain La Liga

# Manual fallback if auto discover returns nothing
# WATCHLIST_FIXTURES=Arsenal v Chelsea:12345:67890

# Shared API budgets (Redis-backed when REDIS_URL set)
FVE_ODDS_API_MAX_CALLS_PER_HOUR=15
FVE_MATCHBOOK_MAX_CALLS_PER_HOUR=1200
FVE_API_FOOTBALL_MAX_CALLS_PER_HOUR=100

REDIS_URL=redis://redis:6379/0
FVE_API_URL=http://localhost:8000
