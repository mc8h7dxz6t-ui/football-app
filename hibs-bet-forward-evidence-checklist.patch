+#!/usr/bin/env bash
+# Football forward evidence operator checklist (C1–C4).
+#
+# C1  sudo bash deploy/cron-hibs-calibration.sh --install
+# C2  Load dashboard while logged in on fixture days (seeds snapshots)
+# C3  scripts/run_forward_backfill_plan.sh
+# C4  Wait for ≥3 matchdays + pred-log-sync → verify_football_evidence_gates.sh
+#
+# Usage:
+#   ./scripts/run_football_evidence_checklist.sh              # status + run automated steps
+#   ./scripts/run_football_evidence_checklist.sh --status     # print checklist only
+#   ./scripts/run_football_evidence_checklist.sh --step C1    # single step
+#   ./scripts/run_football_evidence_checklist.sh --seed       # API seed for C2 (API budget)
+#   ./scripts/run_football_evidence_checklist.sh --watch      # C4 poll until buyer_ready
+#   ./scripts/run_football_evidence_checklist.sh --remote     # SSH to VPS (DEPLOY_HOST)
+set -euo pipefail
+
+ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+cd "${ROOT}"
+
+HOST="${DEPLOY_HOST:-77.68.89.73}"
+USER="${DEPLOY_USER:-root}"
+APP="${DEPLOY_PATH:-/opt/hibs-bet}"
+STATUS_ONLY=0
+SEED=0
+WATCH=0
+REMOTE=0
+RUN_STEPS=1
+STEP_FILTER=""
+INTERVAL="${HIBS_EVIDENCE_WATCH_SEC:-3600}"
+MAX_ROUNDS="${HIBS_EVIDENCE_MAX_ROUNDS:-48}"
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --status) STATUS_ONLY=1; RUN_STEPS=0; shift ;;
+    --seed) SEED=1; shift ;;
+    --watch) WATCH=1; shift ;;
+    --remote) REMOTE=1; shift ;;
+    --no-run) RUN_STEPS=0; shift ;;
+    --step)
+      shift
+      STEP_FILTER="${1:-}"
+      [[ -n "${STEP_FILTER}" ]] || { echo "ERROR: --step requires C1|C2|C3|C4" >&2; exit 2; }
+      shift
+      ;;
+    -h|--help)
+      sed -n '2,16p' "$0"
+      exit 0
+      ;;
+    C1|C2|C3|C4) STEP_FILTER="$1"; shift ;;
+    *) echo "Unknown argument: $1 (see --help)" >&2; exit 2 ;;
+  esac
+done
+
+if [[ "${REMOTE}" -eq 1 ]]; then
+  flags=""
+  [[ "${STATUS_ONLY}" -eq 1 ]] && flags="${flags} --status"
+  [[ "${SEED}" -eq 1 ]] && flags="${flags} --seed"
+  [[ "${WATCH}" -eq 1 ]] && flags="${flags} --watch"
+  [[ "${RUN_STEPS}" -eq 0 ]] && flags="${flags} --no-run"
+  [[ -n "${STEP_FILTER}" ]] && flags="${flags} --step ${STEP_FILTER}"
+  echo "==> Remote checklist on ${USER}@${HOST}:${APP}"
+  ssh -o BatchMode=yes -o ConnectTimeout=25 "${USER}@${HOST}" \
+    "cd '${APP}' && bash scripts/run_football_evidence_checklist.sh ${flags}"
+  exit $?
+fi
+
+if [[ -f "${ROOT}/.env" ]]; then
+  set -a
+  # shellcheck disable=SC1091
+  source "${ROOT}/.env"
+  set +a
+fi
+
+export PYTHONPATH="${ROOT}/src${PYTHONPATH:+:$PYTHONPATH}"
+PY="${ROOT}/.venv/bin/python3"
+[[ -x "${PY}" ]] || PY="python3"
+
+step() { echo ""; echo "==> $*"; }
+
+ensure_evidence_deploy_date() {
+  if grep -q '^HIBS_EVIDENCE_DEPLOY_DATE=' "${ROOT}/.env" 2>/dev/null; then
+    return 0
+  fi
+  local stamp
+  stamp="$(date -u +%Y-%m-%d)"
+  echo "HIBS_EVIDENCE_DEPLOY_DATE=${stamp}" >> "${ROOT}/.env"
+  export HIBS_EVIDENCE_DEPLOY_DATE="${stamp}"
+  step "Set HIBS_EVIDENCE_DEPLOY_DATE=${stamp} in .env"
+}
+
+print_checklist() {
+  "${PY}" -c "
+from hibs_predictor.forward_evidence import football_evidence_checklist
+import json
+d = football_evidence_checklist()
+print('since_deploy:', d.get('since_deploy_iso'))
+print('matchdays_7d:', d.get('matchdays_7d'))
+print('evidence_grade:', d.get('evidence_grade'))
+print('buyer_ready:', d.get('buyer_ready'))
+print('checklist:', d.get('checklist_done'), '/', d.get('checklist_total'))
+print()
+for s in d.get('checklist_steps', []):
+    mark = 'DONE' if s.get('pass') else 'TODO'
+    print(f\"  [{mark}] {s.get('id')}: {s.get('label')}\")
+    print(f\"         {s.get('command')}\")
+    if s.get('message'):
+        print(f\"         {s.get('message')}\")
+if d.get('next_actions'):
+    print()
+    print('Gate next actions:')
+    for a in d['next_actions']:
+        print(f\"  - {a}\")
+"
+}
+
+checklist_json() {
+  "${PY}" -c "
+from hibs_predictor.forward_evidence import football_evidence_checklist
+import json
+print(json.dumps(football_evidence_checklist(), indent=2, default=str))
+"
+}
+
+should_run_step() {
+  local id="$1"
+  [[ -z "${STEP_FILTER}" || "${STEP_FILTER}" == "${id}" ]]
+}
+
+run_c1() {
+  should_run_step C1 || return 0
+  step "C1 — install daily audit cron"
+  if [[ -f "${ROOT}/deploy/cron-hibs-calibration.sh" ]]; then
+    if [[ "$(id -u)" -eq 0 ]]; then
+      bash "${ROOT}/deploy/cron-hibs-calibration.sh" --install
+    else
+      sudo bash "${ROOT}/deploy/cron-hibs-calibration.sh" --install
+    fi
+  else
+    echo "WARN: deploy/cron-hibs-calibration.sh missing" >&2
+  fi
+}
+
+run_c2() {
+  should_run_step C2 || return 0
+  step "C2 — snapshot seeding"
+  if [[ "${SEED}" -eq 1 && -f "${ROOT}/scripts/seed_forward_evidence.sh" ]]; then
+    bash "${ROOT}/scripts/seed_forward_evidence.sh"
+    return 0
+  fi
+  echo "Manual: log in and load the dashboard on fixture days (seeds pre-kickoff snapshots)."
+  echo "API alternative: ./scripts/run_football_evidence_checklist.sh --seed"
+}
+
+run_c3() {
+  should_run_step C3 || return 0
+  step "C3 — forward backfill plan (API budget — may take 20+ min)"
+  if [[ -f "${ROOT}/scripts/run_forward_backfill_plan.sh" ]]; then
+    bash "${ROOT}/scripts/run_forward_backfill_plan.sh"
+  else
+    echo "WARN: scripts/run_forward_backfill_plan.sh missing" >&2
+    return 1
+  fi
+}
+
+run_sync() {
+  step "pred-log-sync (join FT results + closing odds)"
+  "${PY}" -m hibs_predictor.main pred-log-sync --verbose 2>&1 | tail -30 || true
+}
+
+run_c4() {
+  should_run_step C4 || return 0
+  step "C4 — verify football evidence gates"
+  run_sync
+  if bash "${ROOT}/scripts/verify_football_evidence_gates.sh"; then
+    return 0
+  fi
+  return 1
+}
+
+# --- main ---
+step "Football evidence checklist (C1–C4)"
+ensure_evidence_deploy_date
+
+echo ""
+print_checklist
+
+if [[ "${STATUS_ONLY}" -eq 1 ]]; then
+  checklist_json | "${PY}" -c "import json,sys; d=json.load(sys.stdin); sys.exit(0 if d.get('checklist_complete') else 1)"
+  exit $?
+fi
+
+if [[ "${RUN_STEPS}" -eq 1 ]]; then
+  run_c1 || true
+  run_c2 || true
+  if should_run_step C3; then
+    run_c3 || echo "WARN: C3 backfill incomplete" >&2
+    run_sync
+  fi
+fi
+
+round=1
+while true; do
+  if run_c4; then
+    echo ""
+    print_checklist
+    echo ""
+    echo "GREEN — checklist complete, buyer_ready=true"
+    echo "Next: ./scripts/export_b2b_data_room.sh"
+    exit 0
+  fi
+
+  if [[ "${WATCH}" -ne 1 || "${round}" -ge "${MAX_ROUNDS}" ]]; then
+    echo ""
+    print_checklist
+    echo ""
+    echo "AMBER — checklist not complete."
+    echo "  C2: load dashboard on fixture days (or re-run with --seed)"
+    echo "  C4: re-run after ≥3 matchdays + pred-log-sync"
+    echo "  Watch: ./scripts/run_football_evidence_checklist.sh --watch"
+    exit 1
+  fi
+
+  echo ""
+  echo "Watch round ${round}/${MAX_ROUNDS} — sleeping ${INTERVAL}s…"
+  sleep "${INTERVAL}"
+  round=$((round + 1))
+done
