+def _backfill_plan_status(*, since_iso: Optional[str]) -> Dict[str, Any]:
+    """Whether scripts/run_forward_backfill_plan.sh has produced a manifest (C3)."""
+    repo = Path(__file__).resolve().parents[2]
+    path = repo / "data" / "backtest_profiles" / "forward_backfill_plan.json"
+    if not path.is_file():
+        return {
+            "done": False,
+            "path": str(path),
+            "message": "C3 not run — bash scripts/run_forward_backfill_plan.sh",
+        }
+    try:
+        data = json.loads(path.read_text(encoding="utf-8"))
+    except (OSError, json.JSONDecodeError) as exc:
+        return {"done": False, "path": str(path), "message": f"Unreadable backfill manifest: {exc}"}
+    generated = (data.get("generated_at") or "").strip()
+    done = bool(generated)
+    if done and since_iso and generated < since_iso:
+        done = False
+        msg = f"Backfill manifest predates deploy ({since_iso[:10]}) — re-run C3."
+    elif done:
+        msg = f"Backfill manifest at {generated[:19]}Z"
+    else:
+        msg = "Backfill manifest missing generated_at — re-run C3."
+    return {
+        "done": done,
+        "path": str(path),
+        "generated_at": generated or None,
+        "message": msg,
+    }
+
+
+def football_evidence_checklist() -> Dict[str, Any]:
+    """
+    Operator checklist C1–C4 toward ``forward_evidence.buyer_ready``.
+
+    C1  Install daily audit cron on VPS
+    C2  Seed pre-kickoff snapshots (dashboard loads or API seed)
+    C3  Historic odds repair via run_forward_backfill_plan.sh
+    C4  ≥3 matchdays + pred-log-sync → verify_football_evidence_gates.sh green
+    """
+    report = forward_evidence_gates()
+    since = report.get("since_deploy_iso")
+    matchdays = int(report.get("matchdays_7d") or 0)
+    cap_7d = report.get("odds_capture_7d") or {}
+    n_snapshots = int(cap_7d.get("n_snapshots") or 0)
+    by_id = {g["id"]: g for g in report.get("gates", [])}
+
+    c1_pass = bool(by_id.get("F3_cron", {}).get("pass"))
+    c2_pass = matchdays >= 1 or n_snapshots > 0
+    backfill = _backfill_plan_status(since_iso=since)
+    c3_pass = bool(backfill.get("done"))
+    c4_pass = bool(report.get("buyer_ready"))
+    c4_ready_to_verify = matchdays >= MIN_MATCHDAYS_BEFORE_CAPTURE_GATE
+
+    steps: List[Dict[str, Any]] = [
+        {
+            "id": "C1",
+            "label": "Daily audit cron (pred-log-sync pipeline)",
+            "pass": c1_pass,
+            "automated": True,
+            "command": "sudo bash deploy/cron-hibs-calibration.sh --install",
+            "message": by_id.get("F3_cron", {}).get("message", ""),
+        },
+        {
+            "id": "C2",
+            "label": "Snapshot seeding on fixture days",
+            "pass": c2_pass,
+            "automated": False,
+            "command": "Load dashboard while logged in on fixture days",
+            "alt_command": "bash scripts/seed_forward_evidence.sh",
+            "message": (
+                f"{matchdays} matchday(s), {n_snapshots} snapshot(s) in 7d."
+                if c2_pass
+                else "No snapshots in 7d — log in and load dashboard during fixture window."
+            ),
+        },
+        {
+            "id": "C3",
+            "label": "Forward backfill plan (odds repair)",
+            "pass": c3_pass,
+            "automated": True,
+            "command": "bash scripts/run_forward_backfill_plan.sh",
+            "message": backfill.get("message", ""),
+        },
+        {
+            "id": "C4",
+            "label": "Verify gates after matchdays + sync",
+            "pass": c4_pass,
+            "automated": True,
+            "command": "./scripts/verify_football_evidence_gates.sh",
+            "message": (
+                "buyer_ready=true"
+                if c4_pass
+                else (
+                    f"Need ≥{MIN_MATCHDAYS_BEFORE_CAPTURE_GATE} matchdays (have {matchdays}) "
+                    "and daily pred-log-sync before F7–F9 pass."
+                    if not c4_ready_to_verify
+                    else "Matchday threshold met — run pred-log-sync and verify gates."
+                )
+            ),
+        },
+    ]
+
+    done_count = sum(1 for s in steps if s["pass"])
+    return {
+        **report,
+        "checklist_steps": steps,
+        "checklist_done": done_count,
+        "checklist_total": len(steps),
+        "checklist_complete": done_count == len(steps),
+        "c4_ready_to_verify": c4_ready_to_verify,
+        "backfill_plan": backfill,
+    }
+
+
 def _count_matchdays(*, days: int, since_iso: Optional[str]) -> int:
     """Distinct UTC kickoff dates with ≥1 snapshot in window."""
     from hibs_predictor.prediction_log import _db_path, _enabled, init_db
