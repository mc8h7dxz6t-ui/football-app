# Sourced by racing verification cron (www-data). Copy to /opt/hibs-racing/config/verification.cron.env
FVE_METRICS_ROOT=/opt/football-app
HIBS_RACING_DEPLOY_PATH=/opt/hibs-racing
HIBS_RACING_FEATURE_STORE=/opt/hibs-racing/data/feature_store.sqlite
RACING_VERIFICATION_JSONL=/opt/hibs-racing/data/verification/settled_races.jsonl
# Prefer deploy-local log (no root). Override for /var/log if directory is www-data writable:
RACING_VERIFICATION_LOG=/opt/hibs-racing/logs/verification-automation.log
# Shared flock for feature_store writers (verification settlement + hibs-racing daily refresh)
# Default lock path: /opt/hibs-racing/data/feature_store.sqlite.lock
RACING_FEATURE_STORE_LOCK_WAIT_SEC=60
RACING_VERIFICATION_MAX_RACES=2500
RACING_VERIFICATION_MIN_RACES=1000
# hibs-racing VPS: scored history with model_place_prob + finish_pos
# (Do not set upcoming_runners — card table has no results.)
# Institutional++ measurement contract (place vs place, paired benchmark, OOS)
RACING_VERIFICATION_REQUIRE_PAIRED_PLACE_MARKET=1
RACING_VERIFICATION_MIN_PAIRED_PCT=0.95
# Races on or before this date are excluded from verification (strict OOS). Set to last train date.
RACING_VERIFICATION_TRAIN_CUTOFF=2025-12-31
