+"""Tests for cross-product navigation URLs."""
+
+from __future__ import annotations
+
+from hibs_predictor.product_links import (
+    football_home_url,
+    portfolio_api_url,
+    product_bar_context,
+    racing_base_url,
+    racing_cards_url,
+    trading_status_url,
+)
+
+
+def test_same_origin_defaults(monkeypatch):
+    monkeypatch.delenv("HIBS_RACING_BASE_URL", raising=False)
+    monkeypatch.delenv("HIBS_TRADING_STATUS_URL", raising=False)
+    monkeypatch.delenv("HIBS_PORTFOLIO_API_URL", raising=False)
+    monkeypatch.delenv("HIBS_PRODUCTION", raising=False)
+    assert racing_base_url() == "/racing"
+    assert racing_cards_url() == "/racing/cards"
+    assert trading_status_url() == "/harvested-execution"
+    assert portfolio_api_url() == "/api/racing/portfolio/summary"
+
+
+def test_explicit_override(monkeypatch):
+    monkeypatch.setenv("HIBS_RACING_BASE_URL", "http://127.0.0.1:5003")
+    monkeypatch.setenv("HIBS_TRADING_STATUS_URL", "http://127.0.0.1:9110")
+    assert racing_base_url() == "http://127.0.0.1:5003"
+    assert racing_cards_url() == "http://127.0.0.1:5003/cards"
+    assert trading_status_url() == "http://127.0.0.1:9110"
+
+
+def test_product_bar_context_active(monkeypatch):
+    monkeypatch.delenv("HIBS_RACING_BASE_URL", raising=False)
+    ctx = product_bar_context(active="trading")
+    assert ctx["hibs_product_active"] == "trading"
+    assert ctx["hibs_racing_cards_url"] == "/racing/cards"
+    assert ctx["hibs_trading_status_url"] == "/harvested-execution"
+
+
+def test_football_home_default():
+    assert football_home_url() == "/"
