++#!/usr/bin/env python3
++"""Diagnose WORLD_CUP audit rows vs forward CLV (F8) requirements."""
++from __future__ import annotations
++
++import json
++import sqlite3
++import sys
++from pathlib import Path
++
++ROOT = Path(__file__).resolve().parents[1]
++sys.path.insert(0, str(ROOT / "src"))
++
++from hibs_predictor.forward_evidence import evidence_deploy_since_iso
++from hibs_predictor.prediction_log import _db_path
++
++
++def main() -> int:
++    since = evidence_deploy_since_iso()
++    conn = sqlite3.connect(_db_path())
++    rows = conn.execute(
++        """
++        SELECT kickoff_iso, home_name, away_name, captured_at,
++               result_outcome, result_recorded_at,
++               prediction_json, enrich_summary_json
++        FROM prediction_snapshots
++        WHERE league_code = 'WORLD_CUP'
++        ORDER BY kickoff_iso
++        """
++    ).fetchall()
++    conn.close()
++
++    print("since_deploy:", since)
++    print(f"WORLD_CUP snapshot rows: {len(rows)}\n")
++
++    for ko, h, a, cap, ro, rr, pj, ej in rows:
++        post = (ko or "") >= (since or "")
++        try:
++            pred = json.loads(pj or "{}")
++            best = pred.get("best_bet")
++            has_1x2 = bool(pred.get("bookmaker_odds") or pred.get("line_odds"))
++        except Exception:
++            best, has_1x2 = None, False
++        try:
++        clv = json.loads(ej or "{}").get("clv") or {}
++        pp = clv.get("clv_pp")
++        stake = clv.get("clv_stake_outcome")
++        src = clv.get("clv_stake_source")
++    except Exception:
++        pp = stake = src = None
++
++    if ro:
++        status = "SCORED"
++    elif rr:
++        status = "partial"
++    else:
++        status = "PENDING"
++
++    tag = "POST" if post else "PRE"
++    print(f"[{tag}] {status}  {ko}  {h} v {a}")
++    print(f"      captured={cap}  1x2={has_1x2}  best_bet={best}  stake={stake}({src})  clv_pp={pp}")
++
++    return 0
++
++
++if __name__ == "__main__":
++    raise SystemExit(main())
