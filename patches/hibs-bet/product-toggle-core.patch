+    db = tmp_path / "audit.sqlite"
+    monkeypatch.setenv("HIBS_PREDICTION_LOG_DB", str(db))
+    monkeypatch.setenv("HIBS_PREDICTION_LOG_ENABLED", "1")
+    monkeypatch.setenv("HIBS_CLV_LOG_ENABLED", "1")
