+def _apply_clv_closing_to_fixture_snapshots(
+    conn: sqlite3.Connection,
+    *,
+    api_fixture_id: int,
+    stored_fixture_id: Any,
+    closing: Dict[str, Optional[float]],
+) -> int:
+    """Join closing 1X2 and compute clv_pp for all snapshot rows on a fixture."""
+    snap_rows = conn.execute(
+        """
+        SELECT id, enrich_summary_json, prediction_json FROM prediction_snapshots
+        WHERE fixture_id IN (?, ?) AND enrich_summary_json IS NOT NULL
+        """,
+        (api_fixture_id, int(stored_fixture_id)),
+    ).fetchall()
+    updated = 0
+    for sr in snap_rows:
+        try:
+            enrich = json.loads(sr["enrich_summary_json"])
+        except Exception:
+            continue
+        if not isinstance(enrich, dict):
+            continue
+        try:
+            pred = json.loads(sr["prediction_json"] or "{}")
+        except Exception:
+            pred = {}
+        if not isinstance(pred, dict):
+            pred = {}
+        if "clv" not in enrich and enrich.get("odds_available") and pred:
+            enrich["clv"] = _clv_opening_capture({}, pred)
+        if "clv" not in enrich:
+            continue
+        enrich["clv"] = _ensure_clv_stake_fields(enrich["clv"], pred)
+        before = (enrich.get("clv") or {}).get("clv_pp")
+        enrich = _apply_clv_to_enrich_summary(enrich, closing)
+        after = (enrich.get("clv") or {}).get("clv_pp")
+        if after is None and before is None:
+            continue
+        conn.execute(
+            "UPDATE prediction_snapshots SET enrich_summary_json=? WHERE id=?",
+            (json.dumps(enrich, default=str), sr["id"]),
+        )
+        if after is not None:
+            updated += 1
+    if updated:
+        conn.commit()
+    return updated
+
