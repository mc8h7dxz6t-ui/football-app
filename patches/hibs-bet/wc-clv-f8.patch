+def _fixture_needs_clv_backfill(conn: sqlite3.Connection, fixture_id: Any) -> bool:
+    """True when a scored fixture has snapshots missing parseable clv_pp."""
+    rows = conn.execute(
+        """
+        SELECT enrich_summary_json, prediction_json
+        FROM prediction_snapshots
+        WHERE fixture_id = ?
+          AND result_outcome IS NOT NULL AND result_outcome != ''
+        LIMIT 8
+        """,
+        (int(fixture_id),),
+    ).fetchall()
+    for enrich_raw, pred_raw in rows:
+        try:
+            enrich = json.loads(enrich_raw or "{}")
+        except Exception:
+            enrich = {}
+        try:
+            pred = json.loads(pred_raw or "{}")
+        except Exception:
+            pred = {}
+        if not isinstance(pred, dict):
+            continue
+        stake, _ = _resolve_clv_stake_outcome(pred)
+        if not stake:
+            continue
+        clv = enrich.get("clv") if isinstance(enrich, dict) else None
+        if not isinstance(clv, dict):
+            if isinstance(enrich, dict) and enrich.get("odds_available"):
+                return True
+            continue
+        if clv.get("clv_pp") is None:
+            return True
+    return False
+
