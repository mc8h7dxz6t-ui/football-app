+            try:
+                odds_raw = fetch_odds_fn(fid_int)
+                closing = parse_closing_1x2_from_odds_response(odds_raw)
+            except Exception:
+                closing = {"home": None, "draw": None, "away": None}
+            n = _apply_clv_closing_to_fixture_snapshots(
+                conn,
