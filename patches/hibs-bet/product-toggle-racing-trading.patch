@@ -0,0 +1,133 @@
+"""Lightweight racing + trading stack probes for /api/health and product bar status."""
+
+from __future__ import annotations
+
+import json
+import os
+import time
+import urllib.error
+import urllib.request
+from typing import Any, Dict, List, Tuple
+
+from hibs_predictor.product_links import football_production_url, production_mode, racing_base_url
+
+
+def _env_truthy(name: str) -> bool:
+    return (os.getenv(name) or "").strip().lower() in ("1", "true", "yes", "on")
+
+
+def stack_probe_enabled() -> bool:
+    return production_mode() or _env_truthy("HIBS_HEALTH_STACK_PROBE")
+
+
+def _http_probe(url: str, *, timeout: float = 4.0) -> Tuple[bool, str, int]:
+    started = time.monotonic()
+    try:
+        req = urllib.request.Request(url, headers={"User-Agent": "hibs-bet-stack-probe/1.0"})
+        with urllib.request.urlopen(req, timeout=timeout) as resp:
+            body = resp.read().decode("utf-8", errors="replace")
+            latency_ms = int((time.monotonic() - started) * 1000)
+            ok = int(resp.status) == 200
+            if ok and '"ok"' in body:
+                try:
+                    data = json.loads(body)
+                    ok = bool(data.get("ok", True)) if isinstance(data, dict) else ok
+                except Exception:
+                    pass
+            return ok, body[:160], latency_ms
+    except urllib.error.HTTPError as exc:
+        latency_ms = int((time.monotonic() - started) * 1000)
+        try:
+            body = exc.read().decode("utf-8", errors="replace")
+        except Exception:
+            body = str(exc)
+        return False, body[:160], latency_ms
+    except Exception as exc:
+        latency_ms = int((time.monotonic() - started) * 1000)
+        return False, str(exc)[:160], latency_ms
+
+
+def probe_racing_stack() -> Dict[str, Any]:
+    """Ping racing via nginx proxy first, then direct racing base."""
+    football = football_production_url()
+    racing = racing_base_url()
+    candidates: List[Tuple[str, str]] = [
+        ("proxy", f"{football}/api/racing/ping"),
+        ("direct", f"{racing}/api/ping"),
+    ]
+    last_detail = ""
+    last_latency: int | None = None
+    last_url = candidates[0][1]
+    seen = set()
+    for label, url in candidates:
+        if url in seen:
+            continue
+        seen.add(url)
+        last_url = url
+        ok, detail, latency_ms = _http_probe(url)
+        last_detail = detail
+        last_latency = latency_ms
+        if ok:
+            return {
+                "online": True,
+                "status": "live",
+                "probe": label,
+                "url": url,
+                "latency_ms": latency_ms,
+            }
+    return {
+        "online": False,
+        "status": "offline",
+        "probe": "failed",
+        "url": last_url,
+        "detail": last_detail,
+        "latency_ms": last_latency,
+    }
+
+
+def probe_trading_stack(*, timeout: float = 2.5) -> Dict[str, Any]:
+    from hibs_predictor.trading_status import fetch_trading_status, trading_metrics_base_url
+
+    base = trading_metrics_base_url()
+    out: Dict[str, Any] = {
+        "online": False,
+        "status": "offline",
+        "metrics_url": base,
+        "ready": None,
+        "phase": None,
+        "error": None,
+    }
+    try:
+        status = fetch_trading_status(timeout=timeout)
+        online = bool(status.get("online"))
+        out.update(
+            {
+                "online": online,
+                "status": "live" if online else "warm" if status.get("ready") == 200 else "offline",
+                "ready": status.get("ready_text") or status.get("ready"),
+                "phase": (status.get("config") or {}).get("phase"),
+                "error": status.get("error"),
+                "metrics_url": status.get("metrics_url") or base,
+            }
+        )
+    except Exception as exc:
+        out["error"] = str(exc)[:160]
+    return out
+
+
+def augment_stack_ops(health: Dict[str, Any]) -> None:
+    """Attach stack_ops.racing / stack_ops.trading without heavy evidence scoring."""
+    if not stack_probe_enabled():
+        return
+    stack = health.get("stack_ops") if isinstance(health.get("stack_ops"), dict) else {}
+    stack = dict(stack)
+    stack["racing"] = probe_racing_stack()
+    stack["trading"] = probe_trading_stack()
+    if _env_truthy("HIBS_HEALTH_RACING_PROBE"):
+        try:
+            from hibs_predictor.racing_evidence import racing_evidence_gates
+
+            stack["racing_evidence"] = racing_evidence_gates()
+        except Exception as exc:
+            stack["racing_evidence"] = {"error": str(exc)[:120]}
+    health["stack_ops"] = stack
