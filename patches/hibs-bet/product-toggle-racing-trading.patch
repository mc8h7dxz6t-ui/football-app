new file mode 100644
index 0000000..b95ea14
--- /dev/null
+++ b/tests/test_product_links.py
@@ -0,0 +1,43 @@
+"""Tests for cross-product navigation URLs."""
+
+from __future__ import annotations
+
+import pytest
+
+from hibs_predictor.product_links import (
+    football_home_url,
+    portfolio_api_url,
+    product_bar_context,
+    racing_base_url,
+    trading_status_url,
+)
+
+
+def test_production_defaults(monkeypatch):
+    monkeypatch.delenv("HIBS_RACING_BASE_URL", raising=False)
+    monkeypatch.delenv("HIBS_TRADING_STATUS_URL", raising=False)
+    monkeypatch.delenv("HIBS_PORTFOLIO_API_URL", raising=False)
+    monkeypatch.setenv("HIBS_PRODUCTION", "1")
+    monkeypatch.setenv("HIBS_DOMAIN", "hibs-bet.co.uk")
+    assert racing_base_url() == "https://hibs-bet.co.uk/racing"
+    assert trading_status_url() == "https://hibs-bet.co.uk/harvested-execution"
+    assert portfolio_api_url() == "/api/racing/portfolio/summary"
+
+
+def test_dev_defaults(monkeypatch):
+    monkeypatch.delenv("HIBS_PRODUCTION", raising=False)
+    monkeypatch.delenv("HIBS_RACING_BASE_URL", raising=False)
+    monkeypatch.delenv("HIBS_TRADING_STATUS_URL", raising=False)
+    assert racing_base_url() == "http://127.0.0.1:5003"
+    assert "127.0.0.1" in trading_status_url()
+
+
+def test_product_bar_context_active(monkeypatch):
+    monkeypatch.setenv("HIBS_FOOTBALL_HOME_URL", "https://hibs-bet.co.uk/")
+    ctx = product_bar_context(active="trading")
+    assert ctx["hibs_product_active"] == "trading"
+    assert ctx["hibs_football_home_url"].rstrip("/") == "https://hibs-bet.co.uk"
+
+
+def test_football_home_default():
+    assert football_home_url() == "/"
diff --git a/tests/test_stack_ops_probe.py b/tests/test_stack_ops_probe.py
new file mode 100644
index 0000000..c7facf7
--- /dev/null
+++ b/tests/test_stack_ops_probe.py
@@ -0,0 +1,32 @@
+"""Tests for stack_ops_probe."""
+
+from __future__ import annotations
+
+from hibs_predictor.stack_ops_probe import augment_stack_ops, stack_probe_enabled
+
+
+def test_stack_probe_disabled_without_production(monkeypatch):
+    monkeypatch.delenv("HIBS_PRODUCTION", raising=False)
+    monkeypatch.delenv("HIBS_HEALTH_STACK_PROBE", raising=False)
+    assert stack_probe_enabled() is False
+
+
+def test_stack_probe_enabled_in_production(monkeypatch):
+    monkeypatch.setenv("HIBS_PRODUCTION", "1")
+    assert stack_probe_enabled() is True
+
+
+def test_augment_stack_ops_adds_keys(monkeypatch):
+    monkeypatch.setenv("HIBS_HEALTH_STACK_PROBE", "1")
+    monkeypatch.setattr(
+        "hibs_predictor.stack_ops_probe.probe_racing_stack",
+        lambda: {"online": True, "status": "live"},
+    )
+    monkeypatch.setattr(
+        "hibs_predictor.stack_ops_probe.probe_trading_stack",
+        lambda **_: {"online": False, "status": "offline"},
+    )
+    health = {}
+    augment_stack_ops(health)
+    assert health["stack_ops"]["racing"]["online"] is True
+    assert health["stack_ops"]["trading"]["online"] is False
