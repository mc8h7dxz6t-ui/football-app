diff --git a/static/hibs_product_stacks.js b/static/hibs_product_stacks.js
new file mode 100644
index 0000000..d09c200
--- /dev/null
+++ b/static/hibs_product_stacks.js
@@ -0,0 +1,46 @@
+/**
+ * Product bar stack status dots — racing + trading from /api/health stack_ops.
+ */
+(function (global) {
+    'use strict';
+
+    function setDot(id, status, title) {
+        var el = document.getElementById(id);
+        if (!el) return;
+        el.classList.remove('live', 'warm', 'offline');
+        if (status) el.classList.add(status);
+        if (title) el.title = title;
+    }
+
+    function applyStackOps(stackOps) {
+        stackOps = stackOps || {};
+        var racing = stackOps.racing || {};
+        var trading = stackOps.trading || {};
+        var rStatus = racing.online ? 'live' : (racing.status === 'warm' ? 'warm' : 'offline');
+        var tStatus = trading.online ? 'live' : (trading.status === 'warm' ? 'warm' : 'offline');
+        var rTitle = racing.online
+            ? 'Racing live' + (racing.latency_ms != null ? ' (' + racing.latency_ms + 'ms)' : '')
+            : 'Racing offline' + (racing.detail ? ' — ' + racing.detail : '');
+        var tTitle = trading.online
+            ? 'Trading live' + (trading.phase ? ' · ' + trading.phase : '')
+            : 'Trading offline' + (trading.error ? ' — ' + trading.error : '');
+        setDot('hibs-stack-racing', rStatus, rTitle);
+        setDot('hibs-stack-trading', tStatus, tTitle);
+    }
+
+    function poll() {
+        fetch('/api/health', { credentials: 'same-origin' })
+            .then(function (r) { return r.ok ? r.json() : null; })
+            .then(function (d) {
+                if (d && d.stack_ops) applyStackOps(d.stack_ops);
+            })
+            .catch(function () {});
+    }
+
+    if (document.getElementById('hibs-stack-racing') || document.getElementById('hibs-stack-trading')) {
+        poll();
+        setInterval(poll, 120000);
+    }
+
+    global.HibsProductStacks = { apply: applyStackOps, poll: poll };
+})(typeof window !== 'undefined' ? window : global);
