new file mode 100644
index 0000000..3462ae9
--- /dev/null
+++ b/src/hibs_predictor/evidence_sweep.py
@@ -0,0 +1,191 @@
+"""Deterministic promotion-gate threshold sweep (offline, pure, pre-baked).
+
+Pre-baked so that the moment Q2 forward-capture populates value/CLV rows, the desk
+runs optimization profiles instead of scrambling to write analysis scripts. The
+sweep grids over (value-leg magnitude floor) x (CLV magnitude floor) x (promotion
+policy) and reports a precision/recall/F-beta matrix — both raw and **liquidity-
+weighted** — so we can pick the thresholds that maximize promote precision without
+starving viable strategy volume.
+
+Pure: depends only on ``evidence_stats`` (seeded bootstrap = deterministic); no
+I/O, no global state, no RNG of its own. Same ``EvidenceVerdict`` contract.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+import itertools
+from typing import Any, Dict, List, Optional, Sequence, Tuple
+
+from hibs_predictor.evidence_stats import classify_clv_edge, classify_evidence
+
+# Conservative -> aggressive. "all_evidenced" requires every lane that HAS data to
+# pass (corroboration); "any" promotes if either lane passes; lane-specific isolate.
+PROMOTION_POLICIES: Tuple[str, ...] = ("all_evidenced", "any", "value_only", "clv_only")
+
+# Precision-favoring F-beta: beta<1 weights precision above recall (a false promote
+# costs real capital; a starved edge is opportunity cost only).
+DEFAULT_FBETA = 0.5
+
+
+@dataclass(frozen=True)
+class ProfileEvidenceSample:
+    """One strategy profile's evidence (real or synthetic) + ground-truth label.
+
+    ``weight`` is the liquidity / capital-at-risk of the profile, so a false
+    promote on a high-volume loop is penalized proportionally in weighted metrics.
+    """
+
+    profile_id: str
+    per_bet_returns: Sequence[float] = ()       # continuous value-leg unit P&L
+    clv_successes: int = 0
+    clv_n: int = 0
+    clv_avg_pp: Optional[float] = None
+    is_truly_profitable_live: Optional[bool] = None  # ground truth (None = unlabelled)
+    weight: float = 1.0
+
+
+def _fbeta(precision: float, recall: float, beta: float) -> float:
+    b2 = beta * beta
+    denom = b2 * precision + recall
+    if denom <= 0:
+        return 0.0
+    return (1.0 + b2) * precision * recall / denom
+
+
+def profile_promoted(
+    sample: ProfileEvidenceSample,
+    *,
+    value_floor: float,
+    clv_floor: float,
+    policy: str,
+) -> bool:
+    """Promotion decision for one profile under a (value_floor, clv_floor, policy)."""
+    has_value = len(sample.per_bet_returns) > 0
+    has_clv = sample.clv_n > 0
+
+    v_ok = (
+        classify_evidence(sample.per_bet_returns, min_edge_magnitude_pct=value_floor).promotable
+        if has_value
+        else False
+    )
+    c_ok = (
+        classify_clv_edge(
+            sample.clv_successes, sample.clv_n, sample.clv_avg_pp, min_clv_pp=clv_floor
+        ).promotable
+        if has_clv
+        else False
+    )
+
+    if policy == "value_only":
+        return v_ok
+    if policy == "clv_only":
+        return c_ok
+    if policy == "all_evidenced":
+        evidenced = []
+        if has_value:
+            evidenced.append(v_ok)
+        if has_clv:
+            evidenced.append(c_ok)
+        return bool(evidenced) and all(evidenced)
+    # "any" (default aggressive)
+    return v_ok or c_ok
+
+
+def sweep_promotion_thresholds(
+    profiles: List[ProfileEvidenceSample],
+    *,
+    value_hurdles: Sequence[float],
+    clv_hurdles: Sequence[float],
+    policies: Sequence[str] = ("all_evidenced",),
+    beta: float = DEFAULT_FBETA,
+) -> List[Dict[str, Any]]:
+    """Grid-sweep promotion thresholds; return a ranked precision/recall matrix.
+
+    Ranks by **weighted F-beta** (precision-favoring, liquidity-weighted), then
+    weighted precision, then promote volume — i.e. the safest thresholds that still
+    keep the desk fed. Deterministic for a given profile registry.
+    """
+    rows: List[Dict[str, Any]] = []
+
+    for policy, vf, cf in itertools.product(policies, value_hurdles, clv_hurdles):
+        tp = fp = fn = tn = 0
+        tp_w = fp_w = fn_w = 0.0
+        promoted = 0
+        promoted_w = 0.0
+
+        for prof in profiles:
+            promoted_flag = profile_promoted(
+                prof, value_floor=vf, clv_floor=cf, policy=policy
+            )
+            label = prof.is_truly_profitable_live
+            w = float(prof.weight)
+            if promoted_flag:
+                promoted += 1
+                promoted_w += w
+                if label is True:
+                    tp += 1
+                    tp_w += w
+                elif label is False:
+                    fp += 1
+                    fp_w += w
+            elif label is True:
+                fn += 1   # starved a genuinely viable edge
+                fn_w += w
+            elif label is False:
+                tn += 1
+
+        precision = tp / promoted if promoted else 0.0
+        recall = tp / (tp + fn) if (tp + fn) else 0.0
+        w_precision = tp_w / promoted_w if promoted_w else 0.0
+        w_recall = tp_w / (tp_w + fn_w) if (tp_w + fn_w) else 0.0
+
+        rows.append(
+            {
+                "policy": policy,
+                "value_hurdle_pct": vf,
+                "clv_hurdle_pp": cf,
+                "promoted_total": promoted,
+                "true_positives": tp,
+                "false_positives": fp,
+                "starved_viable": fn,
+                "true_negatives": tn,
+                "precision": round(precision, 4),
+                "recall": round(recall, 4),
+                "fbeta": round(_fbeta(precision, recall, beta), 4),
+                "weighted_precision": round(w_precision, 4),
+                "weighted_recall": round(w_recall, 4),
+                "weighted_fbeta": round(_fbeta(w_precision, w_recall, beta), 4),
+                "yield_pct": round(100.0 * promoted / len(profiles), 2) if profiles else 0.0,
+            }
+        )
+
+    # Safest-but-fed first: weighted F-beta, then weighted precision, then volume.
+    rows.sort(
+        key=lambda r: (r["weighted_fbeta"], r["weighted_precision"], r["promoted_total"]),
+        reverse=True,
+    )
+    return rows
+
+
+def best_thresholds(
+    profiles: List[ProfileEvidenceSample],
+    *,
+    value_hurdles: Sequence[float],
+    clv_hurdles: Sequence[float],
+    policies: Sequence[str] = ("all_evidenced",),
+    beta: float = DEFAULT_FBETA,
+    min_promoted: int = 1,
+) -> Optional[Dict[str, Any]]:
+    """Top sweep row that still promotes at least ``min_promoted`` profiles."""
+    matrix = sweep_promotion_thresholds(
+        profiles,
+        value_hurdles=value_hurdles,
+        clv_hurdles=clv_hurdles,
+        policies=policies,
+        beta=beta,
+    )
+    for row in matrix:
+        if row["promoted_total"] >= min_promoted:
+            return row
+    return matrix[0] if matrix else None
diff --git a/tests/test_evidence_sweep.py b/tests/test_evidence_sweep.py
new file mode 100644
index 0000000..9d0188a
--- /dev/null
+++ b/tests/test_evidence_sweep.py
@@ -0,0 +1,79 @@
+"""Tests for the deterministic promotion-threshold sweep harness."""
+
+from hibs_predictor.evidence_sweep import (
+    ProfileEvidenceSample,
+    best_thresholds,
+    profile_promoted,
+    sweep_promotion_thresholds,
+)
+
+
+def _registry():
+    return [
+        # real value edge (low volume)
+        ProfileEvidenceSample("val_real", per_bet_returns=[0.3] * 30,
+                              is_truly_profitable_live=True, weight=1.0),
+        # sub-frictional churn (high volume) -> false positive at zero floor
+        ProfileEvidenceSample("val_churn", per_bet_returns=[0.005] * 200,
+                              is_truly_profitable_live=False, weight=5.0),
+        # real CLV edge (low volume)
+        ProfileEvidenceSample("clv_real", clv_successes=560, clv_n=1000, clv_avg_pp=2.5,
+                              is_truly_profitable_live=True, weight=1.0),
+        # CLV cost-trap (volume) -> false positive at zero floor
+        ProfileEvidenceSample("clv_trap", clv_successes=560, clv_n=1000, clv_avg_pp=0.2,
+                              is_truly_profitable_live=False, weight=3.0),
+    ]
+
+
+def _row(matrix, vf, cf):
+    return next(r for r in matrix if r["value_hurdle_pct"] == vf and r["clv_hurdle_pp"] == cf)
+
+
+def test_sweep_higher_floors_lift_precision_and_remove_cost_traps():
+    matrix = sweep_promotion_thresholds(
+        _registry(), value_hurdles=[0.0, 1.0], clv_hurdles=[0.0, 1.0], policies=["any"]
+    )
+    lo = _row(matrix, 0.0, 0.0)
+    hi = _row(matrix, 1.0, 1.0)
+    assert lo["precision"] == 0.5          # promotes both cost-traps
+    assert hi["precision"] == 1.0          # cost-traps removed
+    assert hi["starved_viable"] == 0       # both real edges survive
+    assert hi["promoted_total"] == 2
+    # Top-ranked row is the safe-but-fed config.
+    assert matrix[0]["value_hurdle_pct"] == 1.0 and matrix[0]["clv_hurdle_pp"] == 1.0
+
+
+def test_sweep_liquidity_weighting_penalizes_high_volume_false_positives():
+    matrix = sweep_promotion_thresholds(
+        _registry(), value_hurdles=[0.0], clv_hurdles=[0.0], policies=["any"]
+    )
+    lo = _row(matrix, 0.0, 0.0)
+    # FPs (churn w5, trap w3) outweigh TPs (w1 each) -> weighted precision << raw.
+    assert lo["weighted_precision"] < lo["precision"]
+    assert lo["weighted_precision"] == 0.2  # 2 / 10 weighted
+
+
+def test_sweep_is_deterministic():
+    a = sweep_promotion_thresholds(_registry(), value_hurdles=[0.0, 1.0],
+                                   clv_hurdles=[0.0, 1.0], policies=["any", "all_evidenced"])
+    b = sweep_promotion_thresholds(_registry(), value_hurdles=[0.0, 1.0],
+                                   clv_hurdles=[0.0, 1.0], policies=["any", "all_evidenced"])
+    assert a == b
+
+
+def test_best_thresholds_picks_safe_but_fed_config():
+    best = best_thresholds(_registry(), value_hurdles=[0.0, 1.0],
+                           clv_hurdles=[0.0, 1.0], policies=["any"], min_promoted=1)
+    assert best is not None
+    assert best["weighted_precision"] == 1.0
+    assert best["promoted_total"] >= 1
+
+
+def test_profile_promoted_respects_policy_for_single_lane():
+    val_only = ProfileEvidenceSample("v", per_bet_returns=[0.3] * 30,
+                                     is_truly_profitable_live=True)
+    # value lane promotes under value_only/any/all_evidenced; clv_only has no data.
+    assert profile_promoted(val_only, value_floor=1.0, clv_floor=0.0, policy="value_only")
+    assert profile_promoted(val_only, value_floor=1.0, clv_floor=0.0, policy="any")
+    assert profile_promoted(val_only, value_floor=1.0, clv_floor=0.0, policy="all_evidenced")
+    assert not profile_promoted(val_only, value_floor=1.0, clv_floor=0.0, policy="clv_only")
