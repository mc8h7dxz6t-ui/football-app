     )
 
 
+def classify_binomial_evidence(
+    successes: int,
+    n: int,
+    *,
+    baseline_proportion: float = 0.50,  # 50% = efficient-market coin flip
+    min_obs_sufficient: int = MIN_PROPORTION_SUFFICIENT,
+    min_obs_thin: int = MIN_PROPORTION_THIN,
+    z: float = 1.96,  # 95% confidence
+) -> EvidenceVerdict:
+    """Grade a binary edge (CLV beat-close, 1X2 strike) with the analytic Wilson CI.
+
+    Sister to :func:`classify_evidence` (which bootstraps continuous per-bet
+    returns). Returns the same :class:`EvidenceVerdict` so promotion gates parse
+    one schema, with ``metric="proportion"`` set so the CI fields are read as the
+    beat-rate % (not ROI %).
+
+    A profile is ``promotable`` only when the sample is large enough **and** the
+    Wilson lower bound strictly clears the baseline. Because thin proportion edges
+    only clear the bar at large n, a strong-but-tiny sample (e.g. 16/20 → Wilson
+    low ~58%) is correctly held at ``thin`` rather than scaled.
+    """
+    n = int(n)
+    if n <= 0:
+        return EvidenceVerdict(
+            grade="empty", n=0, roi_pct=0.0, roi_ci_low_pct=0.0, roi_ci_high_pct=0.0,
+            significant_positive=False, beats_baseline=None, promotable=False,
+            reason="no observations", metric="proportion",
+        )
+
+    successes = max(0, min(int(successes), n))  # guard malformed inputs
+    low, high = wilson_interval(successes, n, z=z)
+    point_pct = (successes / n) * 100.0
+    low_pct = low * 100.0
+    high_pct = high * 100.0
+    baseline_pct = baseline_proportion * 100.0
+
+    beats_baseline = low_pct > baseline_pct
+    significant_positive = low_pct > 50.0  # better than a coin, regardless of baseline
+
+    if n < min_obs_thin:
+        grade = "insufficient"
+    elif n < min_obs_sufficient:
+        grade = "thin"
+    elif beats_baseline:
+        grade = "sufficient"
+    else:
+        grade = "thin"
+
+    promotable = grade == "sufficient"
+
+    if grade == "insufficient":
+        reason = f"n={n} < {min_obs_thin} (too few observations)"
+    elif grade == "thin" and n < min_obs_sufficient:
+        reason = f"n={n} < {min_obs_sufficient} (sample not yet sufficient)"
+    elif promotable:
+        reason = (
+            f"beat-rate 95% CI lower bound {low_pct:.2f}% > baseline {baseline_pct:.2f}% "
+            f"(n={n})"
+        )
+    else:
+        reason = (
+            f"beat-rate 95% CI lower bound {low_pct:.2f}% does not clear "
+            f"baseline {baseline_pct:.2f}%"
+        )
+
+    return EvidenceVerdict(
+        grade=grade,
+        n=n,
+        roi_pct=point_pct,        # proportion point (metric="proportion")
+        roi_ci_low_pct=low_pct,   # Wilson lower bound
+        roi_ci_high_pct=high_pct,  # Wilson upper bound
+        significant_positive=significant_positive,
+        beats_baseline=beats_baseline,
+        promotable=promotable,
+        reason=reason,
+        metric="proportion",
+    )
+
+
 @dataclass(frozen=True)
 class ProportionVerdict:
     """Wilson-interval verdict for a proportion edge (e.g. CLV beat-close > 50%)."""
