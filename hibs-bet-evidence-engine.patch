@@ -0,0 +1,107 @@
+"""Tests for the portable hibs-racing gate-coverage reference (pure, deterministic)."""
+
+import os
+import sys
+
+sys.path.insert(0, os.path.dirname(__file__))
+
+from racing_gate_reference import (  # noqa: E402
+    ADDRESSABLE,
+    DEFAULT_GATE_COLUMN_MANIFEST as M,
+    MAIDEN,
+    classify_race_cohort,
+    coverage_verdict,
+    data_content_fingerprint,
+    dual_definition_density,
+    enrich_recovery_precheck,
+    gate_config_hash,
+    gate_coverage_by_cohort,
+    racing_gate_verdict,
+    wilson_interval,
+)
+
+
+def _runner(cov=True, maiden=False):
+    base = {"race_type": "maiden stakes" if maiden else "handicap",
+            "official_rating": 80, "trainer_rtf": 0.2, "days_since_run": 21}
+    if not cov:
+        base["official_rating"] = None
+    return base
+
+
+# --- Amendment 1: cohort taxonomy ---
+def test_classify_race_cohort():
+    assert classify_race_cohort({"race_type": "Class 3 Handicap"}) == ADDRESSABLE
+    assert classify_race_cohort({"race_type": "EBF Maiden Stakes"}) == MAIDEN
+    assert classify_race_cohort({"is_maiden": True}) == MAIDEN
+
+
+# --- Amendment 3: dual-definition density ---
+def test_dual_definition_density_reports_both():
+    rows = [_runner(cov=True), _runner(cov=True), _runner(cov=False)]
+    rep = dual_definition_density(rows, manifest=M, lane="gate3", source="runners",
+                                  full_columns=("official_rating", "trainer_rtf", "speed_fig_optional"))
+    assert rep["n"] == 3
+    assert rep["gate_critical_density_pct"] == round(100 * 2 / 3, 2)
+    assert "full_set_density_pct" in rep            # optional sparse field drags this lower
+    assert rep["manifest_version"] == "gctcol-v1"
+
+
+# --- Amendment 5: Wilson coverage verdict ---
+def test_coverage_verdict_uses_wilson_lower_bound():
+    # 90/100 -> point 90% but Wilson low ~82.6% < 85 floor -> NOT ready (noise guard).
+    v = coverage_verdict(90, 100, floor_pct=85.0)
+    assert v["coverage_pct"] == 90.0
+    assert v["ci_low_pct"] < 85.0 and v["retest_ready"] is False
+    # 900/1000 -> Wilson low ~88% >= 85 -> ready.
+    v2 = coverage_verdict(900, 1000, floor_pct=85.0)
+    assert v2["retest_ready"] is True and v2["promotable"] is True
+    assert coverage_verdict(0, 0, floor_pct=85.0)["grade"] == "empty"
+
+
+def test_gate_coverage_by_cohort_blocks_on_addressable_only():
+    # Addressable: 900/1000 covered -> passes. Maiden: 10/100 -> fails its floor but non-blocking.
+    rows = [_runner(cov=True) for _ in range(900)] + [_runner(cov=False) for _ in range(100)]
+    rows += [_runner(cov=False, maiden=True) for _ in range(90)] + [_runner(cov=True, maiden=True) for _ in range(10)]
+    audit = gate_coverage_by_cohort(rows, manifest=M, lane="gate3", source="runners")
+    assert audit["cohorts"][ADDRESSABLE]["retest_ready"] is True
+    assert audit["cohorts"][MAIDEN]["retest_ready"] is False
+    assert audit["cohorts"][MAIDEN]["blocking"] is False
+    assert audit["retest_ready"] is True  # maiden failure does NOT block
+
+
+# --- Amendment 2: composite hash stable, fingerprint changes ---
+def test_config_hash_stable_fingerprint_changes():
+    h1 = gate_config_hash(gate_config_version="g3-2026.05", manifest=M)
+    h2 = gate_config_hash(gate_config_version="g3-2026.05", manifest=M)
+    assert h1 == h2  # stable across re-enrich (no row data in it)
+    fp_before = data_content_fingerprint(row_count=4513, covered_count=350,
+                                         window_start="2025-11-01", window_end="2026-05-22")
+    fp_after = data_content_fingerprint(row_count=64691, covered_count=58000,
+                                        window_start="2025-11-01", window_end="2026-05-22")
+    assert fp_before != fp_after  # re-stamp detectable
+
+
+# --- Amendment 4: recovery guards ---
+def test_enrich_recovery_precheck():
+    ok = enrich_recovery_precheck(quota_remaining=100000, quota_needed_estimate=60000,
+                                  checkpoint_date="2025-11-19", window_end="2026-05-22")
+    assert ok.ok is True
+    short = enrich_recovery_precheck(quota_remaining=50000, quota_needed_estimate=60000,
+                                     checkpoint_date="2025-11-19", window_end="2026-05-22")
+    assert short.ok is False  # quota headroom (with margin) fails
+
+
+def test_racing_gate_verdict_cross_lane_contract():
+    passing = gate_coverage_by_cohort(
+        [_runner(cov=True) for _ in range(1000)], manifest=M, lane="gate3", source="runners"
+    )
+    v = racing_gate_verdict([passing], gate_config_version="g3-2026.05", manifest=M,
+                            as_of="2026-06-05T18:00:00+00:00")
+    assert v["lane"] == "racing" and v["promotable"] is True and v["retest_ready"] is True
+    assert v["metric"] == "coverage_proportion"
+
+
+def test_wilson_matches_known_bounds():
+    low, high = wilson_interval(90, 100)
+    assert 0.82 < low < 0.84 and 0.94 < high < 0.95
