@@ -0,0 +1,355 @@
+"""Portable institutional++ reference for hibs-racing gate-coverage (HAND-OFF ARTIFACT).
+
+NOT used by the hibs-bet football engine. Drop into ``hibs-racing`` (or copy the
+functions) — pure stdlib, deterministic, zero external/cross-repo deps so it lifts
+cleanly across the repo boundary. Implements the five amendments to the gate-coverage
+precheck so ``retest_ready`` becomes a defensible, cohort-aware, provenance-stamped
+verdict instead of a single flat density threshold:
+
+  1. Maiden-stratified **addressable cohort** density + floor (maidens are a structural
+     OR ceiling, not an enrich gap — don't chase an unfillable denominator).
+  2. **Composite config hash** (stable across re-enrich) + **data-content fingerprint**
+     (changes on re-stamp) so the re-audit pins the right anchor.
+  3. **Versioned gate-critical column manifest** + **dual-definition density** report so
+     the audit-column tweak is transparent and cannot silently move the goalposts.
+  4. **Enrich-recovery guards** (quota headroom, milestone re-audit cadence, checkpoint).
+  5. **Uniform verdict** (Wilson lower bound on coverage) matching the betting/trading
+     ``EvidenceVerdict`` contract so racing lands in the cross-lane promotion scorecard.
+
+The Wilson interval is inlined verbatim from ``hibs_predictor.evidence_stats`` (already
+unit-tested there) to keep this file dependency-free.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+import hashlib
+import json
+import math
+from typing import Any, Callable, Dict, List, Optional, Sequence, Tuple
+
+# ---------------------------------------------------------------------------
+# Shared statistics (inlined from evidence_stats — single proven definition)
+# ---------------------------------------------------------------------------
+
+def wilson_interval(successes: int, n: int, *, z: float = 1.96) -> Tuple[float, float]:
+    """Wilson score interval (low, high) in [0, 1] for a binomial proportion."""
+    if n <= 0:
+        return (0.0, 0.0)
+    phat = successes / n
+    z2 = z * z
+    denom = 1.0 + z2 / n
+    center = (phat + z2 / (2.0 * n)) / denom
+    margin = (z * math.sqrt((phat * (1.0 - phat) + z2 / (4.0 * n)) / n)) / denom
+    return (max(0.0, center - margin), min(1.0, center + margin))
+
+
+# ---------------------------------------------------------------------------
+# Amendment 1 — cohort taxonomy (addressable vs structural-sparse / maiden)
+# ---------------------------------------------------------------------------
+
+ADDRESSABLE = "addressable"
+MAIDEN = "maiden"
+
+# Coverage floors per cohort. The gate keys off the ADDRESSABLE cohort; maidens are
+# reported against a lower advisory floor and never block (OR is absent by race design).
+DEFAULT_COHORT_FLOORS: Dict[str, float] = {ADDRESSABLE: 85.0, MAIDEN: 60.0}  # percent
+BLOCKING_COHORTS: Tuple[str, ...] = (ADDRESSABLE,)
+
+
+def classify_race_cohort(card: Dict[str, Any]) -> str:
+    """Maiden races lack prior OR/form for most runners -> structural coverage ceiling."""
+    if card.get("is_maiden"):
+        return MAIDEN
+    label = " ".join(
+        str(card.get(k) or "") for k in ("race_type", "race_class", "race_name")
+    ).lower()
+    if "maiden" in label or "mdn" in label.split():
+        return MAIDEN
+    return ADDRESSABLE
+
+
+# ---------------------------------------------------------------------------
+# Amendment 3 — versioned gate-critical column manifest + dual-definition density
+# ---------------------------------------------------------------------------
+
+@dataclass(frozen=True)
+class GateColumnManifest:
+    """Reviewed, versioned set of gate-critical columns (per lane, per source)."""
+
+    version: str
+    runner_columns: Dict[str, Tuple[str, ...]]    # lane -> required runner columns
+    snapshot_columns: Dict[str, Tuple[str, ...]]  # lane -> required snapshot columns
+
+    def columns_for(self, lane: str, source: str) -> Tuple[str, ...]:
+        table = self.runner_columns if source == "runners" else self.snapshot_columns
+        return tuple(table.get(lane, ()))
+
+    def manifest_hash(self) -> str:
+        payload = json.dumps(
+            {
+                "version": self.version,
+                "runner_columns": {k: list(v) for k, v in sorted(self.runner_columns.items())},
+                "snapshot_columns": {k: list(v) for k, v in sorted(self.snapshot_columns.items())},
+            },
+            sort_keys=True,
+            separators=(",", ":"),
+        )
+        return hashlib.sha256(payload.encode("utf-8")).hexdigest()[:16]
+
+
+# Example manifest — REVIEW + version-bump in the hibs-racing repo before use.
+DEFAULT_GATE_COLUMN_MANIFEST = GateColumnManifest(
+    version="gctcol-v1",
+    runner_columns={
+        "gate3": ("official_rating", "trainer_rtf", "days_since_run"),
+        "gate5": ("official_rating", "trainer_rtf", "jockey_rtf", "draw"),
+        "gate7": ("official_rating", "trainer_rtf", "jockey_rtf", "draw", "weight_lbs"),
+    },
+    snapshot_columns={
+        "gate3": ("official_rating", "trainer_rtf"),
+        "gate5": ("official_rating", "trainer_rtf", "jockey_rtf"),
+        "gate7": ("official_rating", "trainer_rtf", "jockey_rtf", "weight_lbs"),
+    },
+)
+
+
+def _row_fully_covered(row: Dict[str, Any], columns: Sequence[str]) -> bool:
+    for col in columns:
+        v = row.get(col)
+        if v is None or v == "":
+            return False
+        if isinstance(v, float) and math.isnan(v):
+            return False
+    return True
+
+
+def column_density(rows: Sequence[Dict[str, Any]], columns: Sequence[str]) -> Tuple[int, int]:
+    """Return (covered_rows, total_rows) where covered = ALL columns present/non-null."""
+    if not columns:
+        return (len(rows), len(rows))
+    covered = sum(1 for r in rows if _row_fully_covered(r, columns))
+    return (covered, len(rows))
+
+
+def dual_definition_density(
+    rows: Sequence[Dict[str, Any]],
+    *,
+    manifest: GateColumnManifest,
+    lane: str,
+    source: str,
+    full_columns: Optional[Sequence[str]] = None,
+) -> Dict[str, Any]:
+    """Density under the gate-critical manifest AND (optionally) the full column set.
+
+    Reporting both makes the audit-narrowing tweak transparent — you can see exactly
+    how much of the gap was sparse *optional* enrich vs genuinely missing gate inputs.
+    """
+    gate_cols = manifest.columns_for(lane, source)
+    gc_cov, n = column_density(rows, gate_cols)
+    out: Dict[str, Any] = {
+        "lane": lane,
+        "source": source,
+        "manifest_version": manifest.version,
+        "manifest_hash": manifest.manifest_hash(),
+        "gate_critical_columns": list(gate_cols),
+        "gate_critical_density_pct": round(100.0 * gc_cov / n, 2) if n else 0.0,
+        "n": n,
+        "covered": gc_cov,
+    }
+    if full_columns is not None:
+        full_cov, _ = column_density(rows, full_columns)
+        out["full_set_density_pct"] = round(100.0 * full_cov / n, 2) if n else 0.0
+        out["full_columns_count"] = len(list(full_columns))
+    return out
+
+
+# ---------------------------------------------------------------------------
+# Amendment 5 — uniform coverage verdict (Wilson lower bound clears the floor)
+# ---------------------------------------------------------------------------
+
+def coverage_verdict(
+    covered: int,
+    n: int,
+    *,
+    floor_pct: float,
+    z: float = 1.96,
+) -> Dict[str, Any]:
+    """Grade a coverage proportion the same way CLV beat-close is graded.
+
+    ``retest_ready`` (== promotable) requires the **Wilson lower bound** to clear the
+    floor — not the point estimate — so the gate never passes on coverage that is
+    statistically within noise of the floor.
+    """
+    if n <= 0:
+        return {
+            "metric": "coverage_proportion", "grade": "empty", "retest_ready": False,
+            "promotable": False, "n": 0, "coverage_pct": None,
+            "ci_low_pct": None, "ci_high_pct": None, "floor_pct": floor_pct,
+            "reason": "no rows in cohort",
+        }
+    low, high = wilson_interval(covered, n, z=z)
+    low_pct, high_pct = low * 100.0, high * 100.0
+    point_pct = 100.0 * covered / n
+    clears = low_pct >= floor_pct
+    return {
+        "metric": "coverage_proportion",
+        "grade": "sufficient" if clears else "thin",
+        "retest_ready": clears,
+        "promotable": clears,
+        "n": n,
+        "coverage_pct": round(point_pct, 2),
+        "ci_low_pct": round(low_pct, 2),
+        "ci_high_pct": round(high_pct, 2),
+        "floor_pct": floor_pct,
+        "reason": (
+            f"coverage 95% CI lower bound {low_pct:.2f}% "
+            f"{'>=' if clears else '<'} floor {floor_pct:.2f}% (n={n})"
+        ),
+    }
+
+
+def gate_coverage_by_cohort(
+    rows: Sequence[Dict[str, Any]],
+    *,
+    manifest: GateColumnManifest,
+    lane: str,
+    source: str,
+    cohort_of: Callable[[Dict[str, Any]], str] = classify_race_cohort,
+    floors: Optional[Dict[str, float]] = None,
+    full_columns: Optional[Sequence[str]] = None,
+) -> Dict[str, Any]:
+    """Per-cohort density + Wilson verdict; blocking cohorts drive ``retest_ready``."""
+    floors = floors or DEFAULT_COHORT_FLOORS
+    gate_cols = manifest.columns_for(lane, source)
+    buckets: Dict[str, List[Dict[str, Any]]] = {}
+    for r in rows:
+        buckets.setdefault(cohort_of(r), []).append(r)
+
+    cohorts: Dict[str, Any] = {}
+    blocking_pass = True
+    blocking_seen = False
+    for cohort, crows in buckets.items():
+        covered, n = column_density(crows, gate_cols)
+        floor = floors.get(cohort, floors.get(ADDRESSABLE, 85.0))
+        verdict = coverage_verdict(covered, n, floor_pct=floor)
+        verdict["blocking"] = cohort in BLOCKING_COHORTS
+        if full_columns is not None:
+            verdict["dual_definition"] = dual_definition_density(
+                crows, manifest=manifest, lane=lane, source=source, full_columns=full_columns
+            )
+        cohorts[cohort] = verdict
+        if cohort in BLOCKING_COHORTS:
+            blocking_seen = True
+            blocking_pass = blocking_pass and verdict["retest_ready"]
+
+    return {
+        "lane": lane,
+        "source": source,
+        "manifest_version": manifest.version,
+        "manifest_hash": manifest.manifest_hash(),
+        "cohorts": cohorts,
+        # retest_ready only if every blocking cohort (addressable) clears its floor.
+        "retest_ready": bool(blocking_seen and blocking_pass),
+    }
+
+
+# ---------------------------------------------------------------------------
+# Amendment 2 — composite config hash (stable) + data fingerprint (changes)
+# ---------------------------------------------------------------------------
+
+def gate_config_hash(*, gate_config_version: str, manifest: GateColumnManifest) -> str:
+    """Stable across re-enrich: hashes only config + column manifest, never row data.
+
+    Use this as ``--snapshot-config-hash`` in the re-audit; it does NOT change when
+    enrich adds rows, so re-stamp -> re-audit stays anchored.
+    """
+    payload = f"{gate_config_version}|{manifest.version}|{manifest.manifest_hash()}"
+    return hashlib.sha256(payload.encode("utf-8")).hexdigest()[:16]
+
+
+def data_content_fingerprint(
+    *, row_count: int, covered_count: int, window_start: str, window_end: str
+) -> str:
+    """Changes whenever enrich/re-stamp alters coverage — assert it moved post-recovery."""
+    payload = f"{window_start}|{window_end}|{row_count}|{covered_count}"
+    return hashlib.sha256(payload.encode("utf-8")).hexdigest()[:16]
+
+
+# ---------------------------------------------------------------------------
+# Amendment 4 — enrich-recovery guards
+# ---------------------------------------------------------------------------
+
+@dataclass
+class RecoveryGuardResult:
+    ok: bool
+    checks: List[Dict[str, Any]] = field(default_factory=list)
+
+
+def enrich_recovery_precheck(
+    *,
+    quota_remaining: int,
+    quota_needed_estimate: int,
+    checkpoint_date: str,
+    window_end: str,
+    milestone_days: int = 30,
+    safety_margin: float = 1.20,
+) -> RecoveryGuardResult:
+    """Pre-flight before kicking off a multi-hour batch-enrich-recovery run."""
+    checks: List[Dict[str, Any]] = []
+
+    need = int(quota_needed_estimate * safety_margin)
+    quota_ok = quota_remaining >= need
+    checks.append({
+        "check": "quota_headroom", "ok": quota_ok,
+        "detail": f"remaining={quota_remaining} need(+{int((safety_margin-1)*100)}%)={need}",
+    })
+
+    behind = checkpoint_date < window_end
+    checks.append({
+        "check": "checkpoint_behind_window", "ok": behind,
+        "detail": f"checkpoint={checkpoint_date} window_end={window_end}"
+        + ("" if behind else " (already current — nothing to recover)"),
+    })
+
+    cadence_ok = milestone_days >= 1
+    checks.append({
+        "check": "milestone_reaudit_cadence", "ok": cadence_ok,
+        "detail": f"re-audit every {milestone_days} enriched days (catch drift early)",
+    })
+
+    return RecoveryGuardResult(ok=all(c["ok"] for c in checks), checks=checks)
+
+
+# ---------------------------------------------------------------------------
+# Cross-lane uniform racing gate verdict (for the promotion scorecard)
+# ---------------------------------------------------------------------------
+
+def racing_gate_verdict(
+    audits: Sequence[Dict[str, Any]],
+    *,
+    gate_config_version: str,
+    manifest: GateColumnManifest,
+    as_of: str,
+) -> Dict[str, Any]:
+    """Collapse per-(lane, source) cohort audits into one cross-lane verdict block.
+
+    ``retest_ready`` is true only when EVERY audited (lane, source) passes its blocking
+    cohorts — matching the betting/trading ``promotable`` contract.
+    """
+    retest_ready = bool(audits) and all(a.get("retest_ready") for a in audits)
+    return {
+        "lane": "racing",
+        "metric": "coverage_proportion",
+        "promotable": retest_ready,
+        "retest_ready": retest_ready,
+        "as_of": as_of,
+        "config_hash": gate_config_hash(gate_config_version=gate_config_version, manifest=manifest),
+        "manifest_version": manifest.version,
+        "audits": list(audits),
+        "reason": (
+            "all blocking cohorts clear floor on both sources"
+            if retest_ready
+            else "one or more blocking cohorts below floor — do not walk-forward / promote"
+        ),
+    }
