diff --git a/tests/test_evidence_stats.py b/tests/test_evidence_stats.py
new file mode 100644
index 0000000..1bd067f
--- /dev/null
+++ b/tests/test_evidence_stats.py
@@ -0,0 +1,78 @@
+"""Tests for institutional++ significance primitives (deterministic)."""
+
+from hibs_predictor.evidence_stats import (
+    bootstrap_mean_ci,
+    classify_evidence,
+    classify_proportion,
+    wilson_interval,
+)
+
+
+def test_wilson_interval_bounds_and_edges():
+    assert wilson_interval(0, 0) == (0.0, 0.0)
+    low, high = wilson_interval(5, 10)
+    assert 0.0 <= low < 0.5 < high <= 1.0
+    # All successes: lower bound below 1.0 (never claims certainty), high == 1.0.
+    low_all, high_all = wilson_interval(10, 10)
+    assert low_all < 1.0 and high_all == 1.0
+
+
+def test_bootstrap_is_deterministic_and_brackets_point():
+    samples = [1.0, -1.0, 2.0, -1.0, 0.5, -1.0, 1.5, -1.0]
+    a = bootstrap_mean_ci(samples, seed=42)
+    b = bootstrap_mean_ci(samples, seed=42)
+    assert a == b  # deterministic for a fixed seed
+    low, point, high = a
+    assert low <= point <= high
+    # Different seed should still bracket the same point estimate.
+    low2, point2, high2 = bootstrap_mean_ci(samples, seed=7)
+    assert point2 == point
+    assert low2 <= point2 <= high2
+
+
+def test_classify_evidence_empty():
+    v = classify_evidence([])
+    assert v.grade == "empty"
+    assert v.promotable is False
+
+
+def test_classify_evidence_insufficient_small_sample():
+    v = classify_evidence([1.0, 1.0, 1.0])  # n < MIN_BETS_THIN
+    assert v.grade == "insufficient"
+    assert v.promotable is False
+
+
+def test_classify_evidence_sufficient_clear_positive_edge():
+    v = classify_evidence([1.0] * 25)  # 25 winning unit bets, ROI +100%
+    assert v.grade == "sufficient"
+    assert v.promotable is True
+    assert v.significant_positive is True
+    assert v.roi_ci_low_pct > 0.0
+
+
+def test_classify_evidence_large_sample_but_negative_not_promotable():
+    v = classify_evidence([-1.0] * 25)
+    assert v.promotable is False
+    assert v.significant_positive is False
+    assert v.grade == "thin"  # large n but edge not separable from zero
+
+
+def test_classify_evidence_baseline_gate():
+    # Constant +20% edge, n=25 -> CI low == 20%.
+    beats = classify_evidence([0.2] * 25, baseline_roi_pct=10.0)
+    assert beats.beats_baseline is True
+    assert beats.grade == "sufficient"
+    fails = classify_evidence([0.2] * 25, baseline_roi_pct=25.0)
+    assert fails.beats_baseline is False
+    assert fails.grade == "thin"  # positive but does not beat baseline
+    assert fails.promotable is False
+
+
+def test_classify_proportion_clv_beat_close():
+    strong = classify_proportion(600, 1000, threshold_pct=50.0)
+    assert strong.beats_threshold is True
+    assert strong.ci_low_pct > 50.0
+    weak = classify_proportion(55, 100, threshold_pct=50.0)
+    assert weak.beats_threshold is False
+    none = classify_proportion(0, 0)
+    assert none.beats_threshold is False
