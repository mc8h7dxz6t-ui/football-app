+"""Institutional++ statistical-significance primitives for edge evidence grading.
+
+Pure-stdlib and **deterministic** (bootstrap is seeded). No I/O, no look-ahead.
+
+Why this exists
+---------------
+Point ROI on a handful of bets is noise. An institutional desk does not scale
+capital on a positive point estimate from a thin sample — it requires the edge
+to be *statistically distinguishable from zero* (and, where a baseline exists,
+from the baseline). This module turns a per-bet return vector (or a
+win/loss proportion such as CLV beat-close) into a defensible verdict:
+
+    insufficient  -> too few observations to say anything
+    thin          -> promising point estimate, not yet proven
+    sufficient    -> large enough sample AND CI lower bound clears the bar
+
+The same primitives grade betting value legs (per-bet returns), 1X2 strike
+rates, and CLV beat-close proportions, so every lane (football / racing /
+trading) can be promoted on one honest standard.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+import math
+import random
+from typing import Optional, Sequence, Tuple
+
+# Default sample-size bars (kept consistent with the legacy count-only grade).
+MIN_BETS_SUFFICIENT = 20
+MIN_BETS_THIN = 8
+# Deterministic bootstrap so CI is reproducible across runs / CI machines.
+DEFAULT_BOOTSTRAP_ITERATIONS = 2000
+DEFAULT_BOOTSTRAP_SEED = 12345
+DEFAULT_CONFIDENCE = 0.95
+
+
+def wilson_interval(successes: int, n: int, *, z: float = 1.96) -> Tuple[float, float]:
+    """Wilson score interval for a binomial proportion (low, high) in [0, 1].
+
+    Far better than the normal approximation for small n / extreme p, which is
+    exactly the regime CLV beat-close and strike-rate evidence start in.
+    """
+    if n <= 0:
+        return (0.0, 0.0)
+    phat = successes / n
+    z2 = z * z
+    denom = 1.0 + z2 / n
+    center = (phat + z2 / (2.0 * n)) / denom
+    margin = (z * math.sqrt((phat * (1.0 - phat) + z2 / (4.0 * n)) / n)) / denom
+    return (max(0.0, center - margin), min(1.0, center + margin))
+
+
+def _percentile(sorted_vals: Sequence[float], q: float) -> float:
+    """Linear-interpolation percentile (q in [0, 1]) on a pre-sorted sequence."""
+    if not sorted_vals:
+        return 0.0
+    if len(sorted_vals) == 1:
+        return float(sorted_vals[0])
+    pos = q * (len(sorted_vals) - 1)
+    lo = int(math.floor(pos))
+    hi = int(math.ceil(pos))
+    if lo == hi:
+        return float(sorted_vals[lo])
+    frac = pos - lo
+    return float(sorted_vals[lo] * (1.0 - frac) + sorted_vals[hi] * frac)
+
+
+def bootstrap_mean_ci(
+    samples: Sequence[float],
+    *,
+    confidence: float = DEFAULT_CONFIDENCE,
+    iterations: int = DEFAULT_BOOTSTRAP_ITERATIONS,
+    seed: int = DEFAULT_BOOTSTRAP_SEED,
+) -> Tuple[float, float, float]:
+    """Deterministic bootstrap CI for the mean: returns (low, point, high).
+
+    Used on a per-bet return vector (e.g. +`odds-1` on a win, `-1` on a loss).
+    The point estimate is the plain mean; low/high are percentile-bootstrap
+    bounds. Deterministic for a given (samples, seed) so CI is reproducible.
+    """
+    n = len(samples)
+    if n == 0:
+        return (0.0, 0.0, 0.0)
+    point = sum(samples) / n
+    if n == 1:
+        return (point, point, point)
+    rng = random.Random(seed)
+    means = []
+    data = list(samples)
+    for _ in range(max(1, iterations)):
+        total = 0.0
+        for _ in range(n):
+            total += data[rng.randrange(n)]
+        means.append(total / n)
+    means.sort()
+    alpha = (1.0 - confidence) / 2.0
+    low = _percentile(means, alpha)
+    high = _percentile(means, 1.0 - alpha)
+    return (low, point, high)
+
+
+@dataclass(frozen=True)
+class EvidenceVerdict:
+    """Significance-aware grade for an edge sample (institutional promotion gate)."""
+
+    grade: str  # "empty" | "insufficient" | "thin" | "sufficient"
+    n: int
+    roi_pct: float
+    roi_ci_low_pct: float
+    roi_ci_high_pct: float
+    significant_positive: bool  # CI lower bound clears zero
+    beats_baseline: Optional[bool]  # vs baseline_roi_pct (None if no baseline)
+    promotable: bool  # sufficient sample + significant + (beats baseline if given)
+    reason: str
+
+    def as_dict(self) -> dict:
+        return {
+            "grade": self.grade,
+            "n": self.n,
+            "roi_pct": round(self.roi_pct, 2),
+            "roi_ci_low_pct": round(self.roi_ci_low_pct, 2),
+            "roi_ci_high_pct": round(self.roi_ci_high_pct, 2),
+            "significant_positive": self.significant_positive,
+            "beats_baseline": self.beats_baseline,
+            "promotable": self.promotable,
+            "reason": self.reason,
+        }
+
+
+def classify_evidence(
+    per_bet_returns: Sequence[float],
+    *,
+    baseline_roi_pct: Optional[float] = None,
+    min_bets_sufficient: int = MIN_BETS_SUFFICIENT,
+    min_bets_thin: int = MIN_BETS_THIN,
+    confidence: float = DEFAULT_CONFIDENCE,
+    iterations: int = DEFAULT_BOOTSTRAP_ITERATIONS,
+    seed: int = DEFAULT_BOOTSTRAP_SEED,
+) -> EvidenceVerdict:
+    """Grade an edge from a per-bet return vector with bootstrap significance.
+
+    ``per_bet_returns`` are unit-stake P&L per leg (win: ``odds-1``, loss: ``-1``).
+    A profile is only ``promotable`` when the sample is large enough AND the
+    bootstrap ROI CI lower bound clears 0 AND (if a baseline is supplied) the
+    lower bound clears the baseline ROI. This is the gate that stops us scaling
+    stake on a lucky 3-bet sample.
+    """
+    n = len(per_bet_returns)
+    if n == 0:
+        return EvidenceVerdict(
+            grade="empty", n=0, roi_pct=0.0, roi_ci_low_pct=0.0, roi_ci_high_pct=0.0,
+            significant_positive=False, beats_baseline=None, promotable=False,
+            reason="no settled legs",
+        )
+
+    low, point, high = bootstrap_mean_ci(
+        per_bet_returns, confidence=confidence, iterations=iterations, seed=seed
+    )
+    roi_pct = point * 100.0
+    low_pct = low * 100.0
+    high_pct = high * 100.0
+    significant_positive = low_pct > 0.0
+
+    beats_baseline: Optional[bool] = None
+    if baseline_roi_pct is not None:
+        beats_baseline = low_pct > float(baseline_roi_pct)
+
+    if n < min_bets_thin:
+        grade = "insufficient"
+    elif n < min_bets_sufficient:
+        grade = "thin"
+    elif significant_positive and (beats_baseline is None or beats_baseline):
+        grade = "sufficient"
+    else:
+        # Large sample but the edge is not statistically separable from zero/baseline.
+        grade = "thin"
+
+    promotable = grade == "sufficient"
+
+    if grade == "insufficient":
+        reason = f"n={n} < {min_bets_thin} (too few legs)"
+    elif grade == "thin" and n < min_bets_sufficient:
+        reason = f"n={n} < {min_bets_sufficient} (sample not yet sufficient)"
+    elif grade == "thin":
+        if not significant_positive:
+            reason = f"ROI 95% CI lower bound {low_pct:.2f}% does not clear 0"
+        else:
+            reason = f"does not beat baseline {baseline_roi_pct}% on CI lower bound"
+    else:
+        reason = (
+            f"n={n}, ROI CI lower bound {low_pct:.2f}% > "
+            f"{0.0 if baseline_roi_pct is None else baseline_roi_pct}"
+        )
+
+    return EvidenceVerdict(
+        grade=grade, n=n, roi_pct=roi_pct, roi_ci_low_pct=low_pct, roi_ci_high_pct=high_pct,
+        significant_positive=significant_positive, beats_baseline=beats_baseline,
+        promotable=promotable, reason=reason,
+    )
+
+
+@dataclass(frozen=True)
+class ProportionVerdict:
+    """Wilson-interval verdict for a proportion edge (e.g. CLV beat-close > 50%)."""
+
+    n: int
+    rate_pct: float
+    ci_low_pct: float
+    ci_high_pct: float
+    threshold_pct: float
+    beats_threshold: bool  # CI lower bound clears the threshold
+    reason: str
+
+    def as_dict(self) -> dict:
+        return {
+            "n": self.n,
+            "rate_pct": round(self.rate_pct, 2),
+            "ci_low_pct": round(self.ci_low_pct, 2),
+            "ci_high_pct": round(self.ci_high_pct, 2),
+            "threshold_pct": self.threshold_pct,
+            "beats_threshold": self.beats_threshold,
+            "reason": self.reason,
+        }
+
+
+def classify_proportion(
+    successes: int,
+    n: int,
+    *,
+    threshold_pct: float = 50.0,
+    z: float = 1.96,
+) -> ProportionVerdict:
+    """Grade a proportion edge (e.g. CLV beat-close) via Wilson lower bound.
+
+    CLV beat-close is the most sample-efficient proof of a line-shopping edge:
+    "we beat the closing line more than half the time, with confidence."
+    ``beats_threshold`` requires the Wilson lower bound to clear ``threshold_pct``.
+    """
+    low, high = wilson_interval(int(successes), int(n), z=z)
+    rate = (successes / n) if n > 0 else 0.0
+    low_pct = low * 100.0
+    high_pct = high * 100.0
+    beats = n > 0 and low_pct > threshold_pct
+    if n <= 0:
+        reason = "no observations"
+    elif beats:
+        reason = f"Wilson lower bound {low_pct:.2f}% > {threshold_pct}% (edge confirmed)"
+    else:
+        reason = f"Wilson lower bound {low_pct:.2f}% does not clear {threshold_pct}%"
+    return ProportionVerdict(
+        n=int(n), rate_pct=rate * 100.0, ci_low_pct=low_pct, ci_high_pct=high_pct,
+        threshold_pct=float(threshold_pct), beats_threshold=beats, reason=reason,
+    )
